<script>
// ── Recent students on dashboard ──────────────────────────
(async function loadRecent() {
  const data = await fetch('api.php?action=list').then(r => r.json());
  const tbody = document.getElementById('recent-tbody');
  if (!data.success || !data.students.length) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:24px">No students yet.</td></tr>';
    return;
  }
  const recent = data.students.slice(0, 6);
  tbody.innerHTML = recent.map(s => {
    const initials = s.full_name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    const badgeClass = {Active:'badge-active',Inactive:'badge-inactive',Graduated:'badge-graduated'}[s.status]??'';
    const date = new Date(s.created_at).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
    return `<tr>
      <td><div class="td-name">
        <div class="avatar">${initials}</div>
        <div><strong>${s.full_name}</strong><small>${s.email}</small></div>
      </div></td>
      <td>${s.course}</td>
      <td>${s.phone}</td>
      <td><span class="badge ${badgeClass}">${s.status}</span></td>
      <td>${date}</td>
    </tr>`;
  }).join('');
  document.getElementById('nav-count').textContent = data.students.length;
})();
</script>

